{
  "name": "@omit-design/preset-mobile",
  "version": "0.1.0",
  "type": "module",
  "description": "Mobile design preset for omit-design: Om* whitelist components, --om-* / --ion-* token map, Ionic 8 runtime.",
  "main": "./index.ts",
  "sideEffects": [
    "*.css",
    "./index.ts"
  ],
  "exports": {
    ".": "./index.ts",
    "./components": "./components/index.ts",
    "./tokens": "./tokens/index.ts",
    "./preset.manifest": "./preset.manifest.ts",
    "./theme/variables.css": "./theme/variables.css",
    "./templates/*": "./templates/*",
    "./PATTERNS.md": "./PATTERNS.md"
  },
  "files": [
    "index.ts",
    "components",
    "tokens",
    "theme",
    "templates",
    "preset.manifest.ts",
    "catalog.tsx",
    "PATTERNS.md",
    "README.md"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@ionic/react": "^8",
    "ionicons": "^7",
    "react": "^19",
    "react-router-dom": "^6"
  }
}

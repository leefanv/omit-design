{
  "name": "@omit-design/engine",
  "version": "0.2.0",
  "type": "module",
  "description": "omit-design runtime: registry, glob discovery, inspect overlay, theme editor, capture, shell. Pure UI library — no router boot, no module-level side effects.",
  "exports": {
    "./shell": "./src/shell/index.ts",
    "./registry": "./src/registry/index.ts",
    "./discovery": "./src/discovery/index.ts",
    "./preset": "./src/preset/index.ts",
    "./capture": "./src/capture/index.ts",
    "./inspect/*": "./src/inspect/*",
    "./theme-editor/*": "./src/theme-editor/*"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leefanv/omit-design.git",
    "directory": "packages/engine"
  },
  "homepage": "https://github.com/leefanv/omit-design/tree/main/packages/engine#readme",
  "bugs": "https://github.com/leefanv/omit-design/issues",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "html-to-image": "^1.11",
    "zustand": "^5"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^6"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.7"
  }
}
